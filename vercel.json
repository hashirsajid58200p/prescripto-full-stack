{
  "services": {
    "frontend": {
      "root": "frontend",
      "framework": "vite"
    },
    "admin": {
      "root": "admin",
      "framework": "vite"
    },
    "backend": {
      "root": "backend"
    }
  },
  "rewrites": [
    {
      "source": "/api(/.*)?",
      "destination": {
        "type": "service",
        "service": "backend"
      }
    },
    {
      "source": "/admin(/.*)?",
      "destination": {
        "type": "service",
        "service": "admin"
      }
    },
    {
      "source": "/(.*)",
      "destination": {
        "type": "service",
        "service": "frontend"
      }
    }
  ]
}
